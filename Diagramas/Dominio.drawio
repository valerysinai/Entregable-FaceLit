        </mxCell>
        <mxCell id="Td95L9fzwFeFqEXXiJGW-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;Un término (dependiendo del tipo de termino&amp;nbsp; ) puede ser aceptado por muchos usuarios.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;Cada aceptación corresponde a una solo tipo de termino&amp;nbsp; según los términos&amp;nbsp;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
