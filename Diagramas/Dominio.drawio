        <mxCell id="3EPYsQfPQCr6hpeAwaVy-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="&lt;font style=&quot;color: light-dark(rgb(0, 255, 0), rgb(0, 255, 0));&quot;&gt;ACEPTACION DE TERMINOS Y CONDICIONES --- TERNIMOS Y CONDICIONES : RELACION 1 : N&lt;/font&gt;" vertex="1">
