        <mxCell id="1yGthClYbt9OTikTjs5R-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="&lt;font style=&quot;color: light-dark(rgb(0, 204, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;font-size: 36px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Recordar de que No existe la entidad de aprendiz, se usa Usuario + rol y se asocia con ficha_Usuario.&amp;nbsp;&lt;br&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;p data-start=&quot;2490&quot; data-end=&quot;2523&quot;&gt;&lt;strong data-start=&quot;2493&quot; data-end=&quot;2501&quot;&gt;PERO&lt;/strong&gt; (esto es importante):&lt;/p&gt;&lt;ul data-start=&quot;2524&quot; data-end=&quot;2698&quot;&gt;&lt;li data-start=&quot;2524&quot; data-end=&quot;2641&quot;&gt;&lt;p data-start=&quot;2526&quot; data-end=&quot;2564&quot;&gt;En reglas de negocio debes restringir:&lt;/p&gt;&lt;ul data-start=&quot;2567&quot; data-end=&quot;2641&quot;&gt;&lt;li data-start=&quot;2567&quot; data-end=&quot;2641&quot;&gt;&lt;p data-start=&quot;2569&quot; data-end=&quot;2641&quot;&gt;Solo &lt;strong data-start=&quot;2574&quot; data-end=&quot;2603&quot;&gt;usuarios con rol APRENDIZ&lt;/strong&gt; pueden estar activos en Ficha_Usuario&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-start=&quot;2642&quot; data-end=&quot;2698&quot;&gt;&lt;p data-start=&quot;2644&quot; data-end=&quot;2698&quot;&gt;Eso &lt;strong data-start=&quot;2648&quot; data-end=&quot;2682&quot;&gt;NO es un problema del diagrama&lt;/strong&gt;, es del sistema&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="1034" x="4512" y="401" as="geometry" />
        </mxCell>
        <mxCell id="pgPtkZWmtuEf0N-upzVr-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;p data-start=&quot;1394&quot; data-end=&quot;1445&quot;&gt;&lt;strong data-start=&quot;1394&quot; data-end=&quot;1407&quot;&gt;Escenario Excepcion de la ficha&lt;/strong&gt;&lt;/p&gt;&lt;p data-start=&quot;1447&quot; data-end=&quot;1459&quot;&gt;Paso a paso:&lt;/p&gt;&lt;ol data-start=&quot;1460&quot; data-end=&quot;1557&quot;&gt;&lt;li data-start=&quot;1460&quot; data-end=&quot;1488&quot;&gt;&lt;p data-start=&quot;1463&quot; data-end=&quot;1488&quot;&gt;Admin selecciona Ficha ( 3145555 )&amp;nbsp;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;1489&quot; data-end=&quot;1516&quot;&gt;&lt;p data-start=&quot;1492&quot; data-end=&quot;1516&quot;&gt;Registra motivo y fechas ( 3/01/2026 la ficha no puso usar el ambiente 209 por mantenimiento, se debe usar un ambiente&amp;nbsp; alterno que es el 208)&amp;nbsp;&amp;nbsp;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;1489&quot; data-end=&quot;1516&quot;&gt;&lt;p data-start=&quot;1492&quot; data-end=&quot;1516&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Sistema marca excepción de ficha&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="229" width="804" x="3601" y="1334" as="geometry" />
